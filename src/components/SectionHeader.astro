---
interface Props {
  numeral: string;
  title: string;
  kicker?: string;
  id?: string;
  highlight?: boolean;
}
const { numeral, title, kicker, id, highlight = false } = Astro.props;
---
<header
  id={id}
  class="max-w-site mx-auto px-5 sm:px-8 mt-16 sm:mt-24 mb-10 sm:mb-14"
  data-fade
>
  <div class="grid grid-cols-12 gap-x-4 sm:gap-x-6 items-end">
    <div class="col-span-12 sm:col-span-2 mb-4 sm:mb-0">
      <span class="type-mono text-ink-soft">{numeral} / Parte</span>
    </div>
    <div class="col-span-12 sm:col-span-10">
      {kicker && <p class="type-mono text-ink-soft mb-3">{kicker}</p>}
      <h2 class="type-h1 font-mono">
        {highlight ? <span class="highlight-chip">{title}</span> : title}
      </h2>
    </div>
  </div>
  <hr class="hr-fine mt-8 sm:mt-10" />
</header>
